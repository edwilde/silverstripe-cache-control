{
    "name": "edwilde/silverstripe-cache-control",
    "description": "SilverStripe module for managing cache-control headers at site and page level",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "cache",
        "cache-control",
        "headers",
        "performance"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "php": "^8.1",
        "silverstripe/framework": "^5.0",
        "silverstripe/cms": "^5.0",
        "unclecheese/display-logic": "^3.0",
        "nswdpc/silverstripe-cache-headers": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "silverstripe/recipe-testing": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Edwilde\\CacheControl\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Edwilde\\CacheControl\\Tests\\": "tests/"
        }
    },
    "extra": {
        "expose": [
            "client"
        ],
        "project-files-installed": [
            "behat.yml",
            "phpunit.xml.dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/recipe-plugin": true,
            "silverstripe/vendor-plugin": true
        }
    }
}
